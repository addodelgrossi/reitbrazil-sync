# reitbrazil-sync — environment configuration
# Copy to .env and fill in real values. Never commit .env.

# ---- Required ----
INGEST_BRAPI_TOKEN=your-brapi-pro-token-here
INGEST_GCP_PROJECT=reitbrazil
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# ---- BigQuery ----
INGEST_BQ_DATASET_RAW=reitbrazil_raw
INGEST_BQ_DATASET_CANON=reitbrazil_canon
INGEST_BQ_LOCATION=southamerica-east1

# ---- GCS ----
INGEST_GCS_BUCKET=reitbrazil-db
INGEST_GCS_KEY_LATEST=latest/reitbrazil.db
INGEST_GCS_PREFIX_HISTORY=history
INGEST_GCS_KEY_METADATA=latest/metadata.json

# ---- GitHub (monthly release only) ----
INGEST_GITHUB_TOKEN=ghp_your_pat_with_contents_write
INGEST_GITHUB_REPO=addodelgrossi/reitbrazil

# ---- Behaviour ----
INGEST_LOG_LEVEL=info
INGEST_LOG_FORMAT=json
INGEST_RATE_LIMIT_RPS=3
INGEST_HTTP_TIMEOUT=30s

# ---- Quality gate ----
INGEST_MIN_FUND_COUNT=100
INGEST_MAX_PRICE_LAG_DAYS=3
